# LiteLLM Gateway Configuration
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-master-key-replace-with-secure-key

# Langfuse Integration
LANGFUSE_PUBLIC_KEY=pk-lf-xxx-replace-with-your-key
LANGFUSE_SECRET_KEY=sk-lf-xxx-replace-with-your-key
LANGFUSE_HOST=http://langfuse:3000

# API Key Configuration
API_KEYS_FILE=/app/config/api_keys.json

# vLLM Backend
VLLM_API_BASE=http://vllm:8000/v1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Trace Buffering
TRACE_BUFFER_DIR=/app/data/trace_buffer
TRACE_BUFFER_MAX_SIZE_MB=100
FLUSH_INTERVAL_SECONDS=60
